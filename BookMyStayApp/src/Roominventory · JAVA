import java.util.*;
 
class RoomInventory {
 
    private Map<String, Integer> rooms;
 
    public RoomInventory() {
        rooms = new HashMap<>();
        rooms.put("Single", 2);
        rooms.put("Double", 2);
        rooms.put("Suite",  1);
    }
 
    // Check if a room type has availability
    public boolean isAvailable(String roomType) {
        return rooms.getOrDefault(roomType, 0) > 0;
    }
 
    // Decrement inventory after allocation
    public void decrement(String roomType) {
        int current = rooms.getOrDefault(roomType, 0);
        if (current > 0) {
            rooms.put(roomType, current - 1);
        }
    }
 
    // Increment inventory after cancellation (rollback)
    public void increment(String roomType) {
        rooms.put(roomType, rooms.getOrDefault(roomType, 0) + 1);
    }
 
    // Return a copy of the inventory map (for persistence/reporting)
    public Map<String, Integer> getRoomAvailability() {
        return new HashMap<>(rooms);
    }
 
    // Print current inventory state
    public void printInventory() {
        for (Map.Entry<String, Integer> entry : rooms.entrySet()) {
            System.out.println("  " + entry.getKey() +
                               ": " + entry.getValue() + " available");
        }
    }
}
